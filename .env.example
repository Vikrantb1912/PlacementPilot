FLASK_DEBUG=True
FLASK_HOST=0.0.0.0
FLASK_PORT=5000

# ── Session / Security ────────────────────────────────────────
SESSION_LIFETIME_MINUTES=120
MAX_CHAT_HISTORY=50

# ── Logging ───────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=logs/placementpilot.log

# ── Rate Limiting (requests per minute per user) ──────────────
RATE_LIMIT_RPM=30
